import cheerio from 'cheerio-without-node-native';
import { BASE_URL, HEADERS, fetchText } from './http.js';

function isHttpUrl(value) {
    return typeof value === 'string' && /^https?:\/\//i.test(value);
}

function cleanText(value) {
    return String(value || '')
        .toLowerCase()
        .replace(/&[^;]+;/g, ' ')
        .replace(/[^\p{L}\p{N}\s]/gu, ' ')
        .replace(/\s+/g, ' ')
        .trim();
}

function decodeSlugFromCanonical(canonicalHref) {
    if (!canonicalHref) return '';

    // Canonical URL format is usually /movie/<id>-<slug> or /tv/<id>-<slug>
    const last = canonicalHref.split('/').filter(Boolean).pop() || '';
    const slug = last.replace(/^\d+-/, '');
    return slug.replace(/-/g, ' ').trim();
}

function parseYearFromTitleTag(titleTag) {
    const match = String(titleTag || '').match(/\((\d{4})\)/);
    return match ? match[1] : '';
}

function unique(values) {
    return Array.from(new Set(values.filter(Boolean)));
}

function resolveQualityFromPage($) {
    const text = $('body').text();

    if (/2160p/i.test(text)) return '2160p';
    if (/1080p/i.test(text)) return '1080p';
    if (/720p/i.test(text)) return '720p';
    if (/480p/i.test(text)) return '480p';

    return 'WEB';
}

async function resolveTmdbMeta(tmdbId, mediaType) {
    const kind = mediaType === 'movie' ? 'movie' : 'tv';
    const tmdbUrl = `https://www.themoviedb.org/${kind}/${tmdbId}`;

    const html = await fetchText(tmdbUrl, {
        headers: {
            ...HEADERS,
            Referer: 'https://www.themoviedb.org/',
        },
    });

    const $ = cheerio.load(html);
    const titleTag = $('title').first().text() || '';
    const canonical = $('link[rel="canonical"]').attr('href') || '';

    const titleFromCanonical = decodeSlugFromCanonical(canonical);
    const year = parseYearFromTitleTag(titleTag);

    const normalizedTitle = cleanText(titleFromCanonical || titleTag);

    return {
        title: normalizedTitle,
        year,
    };
}

async function searchCandidates(query) {
    if (!query) return [];

    const searchUrl = `${BASE_URL}/?s=${encodeURIComponent(query)}`;
    const html = await fetchText(searchUrl, {
        headers: {
            ...HEADERS,
            Referer: `${BASE_URL}/main`,
        },
    });

    const $ = cheerio.load(html);
    const urls = [];

    $('a[href]').each((_, el) => {
        const href = $(el).attr('href');
        if (!href) return;

        if (/^https?:\/\//i.test(href) && /^https?:\/\/web\d+x\.faselhdx\.best\//i.test(href)) {
            if (/\/(movies|series|episodes)\//i.test(href)) {
                urls.push(href);
            }
        }
    });

    return unique(urls);
}

function scoreCandidate(url, mediaType, season, episode, title, year) {
    const lower = url.toLowerCase();
    let score = 0;

    if (mediaType === 'movie' && /\/movies\//.test(lower)) score += 8;
    if (mediaType === 'tv' && /\/episodes\//.test(lower)) score += 10;
    if (mediaType === 'tv' && /\/series\//.test(lower)) score += 4;

    if (year && lower.includes(year)) score += 2;

    const normalizedUrl = cleanText(decodeURIComponent(lower));
    const titleWords = unique(title.split(' ').filter(w => w.length > 2));

    let wordHits = 0;
    for (const word of titleWords) {
        if (normalizedUrl.includes(word)) {
            wordHits += 1;
        }
    }
    score += Math.min(wordHits, 5);

    if (mediaType === 'tv') {
        if (season && new RegExp(`(?:season|الموسم)\\s*${season}`, 'i').test(normalizedUrl)) {
            score += 3;
        }
        if (episode && new RegExp(`(?:episode|الحلقة)\\s*${episode}`, 'i').test(normalizedUrl)) {
            score += 4;
        }
    }

    return score;
}

async function resolvePageUrl(tmdbId, mediaType, season, episode) {
    if (isHttpUrl(tmdbId)) {
        return tmdbId;
    }

    const tmdbMeta = await resolveTmdbMeta(tmdbId, mediaType);

    const queries = [];
    if (tmdbMeta.title && tmdbMeta.year) queries.push(`${tmdbMeta.title} ${tmdbMeta.year}`);
    if (tmdbMeta.title) queries.push(tmdbMeta.title);

    if (mediaType === 'tv' && tmdbMeta.title && season && episode) {
        queries.unshift(`${tmdbMeta.title} season ${season} episode ${episode}`);
        queries.unshift(`${tmdbMeta.title} الموسم ${season} الحلقة ${episode}`);
    }

    const allCandidates = [];
    for (const query of unique(queries)) {
        const urls = await searchCandidates(query);
        allCandidates.push(...urls);
        if (allCandidates.length >= 6) break;
    }

    const candidates = unique(allCandidates);
    if (candidates.length === 0) {
        return '';
    }

    const ranked = candidates
        .map(url => ({
            url,
            score: scoreCandidate(url, mediaType, season, episode, tmdbMeta.title || '', tmdbMeta.year || ''),
        }))
        .sort((a, b) => b.score - a.score);

    return ranked[0]?.url || '';
}

function extractPlayerUrls($) {
    const urls = [];

    // Tabs contain onclick handlers with direct player_token URLs.
    $('ul.tabs-ul li').each((_, li) => {
        const onclick = $(li).attr('onclick') || '';
        const match = onclick.match(/'(https?:\/\/[^']+\/video_player\?player_token=[^']+)'/i);
        if (match && match[1]) {
            urls.push(match[1]);
        }
    });

    const iframeUrl = $('iframe[name="player_iframe"]').attr('data-src') || $('iframe[name="player_iframe"]').attr('src');
    if (iframeUrl && /video_player\?player_token=/i.test(iframeUrl)) {
        urls.push(iframeUrl);
    }

    return unique(urls);
}

function extractInlineScripts(html) {
    const scripts = [];
    const regex = /<script[^>]*>([\s\S]*?)<\/script>/gi;
    let match;

    while ((match = regex.exec(html)) !== null) {
        const content = String(match[1] || '').trim();
        if (content) scripts.push(content);
    }

    return scripts;
}

function findMatchingBrace(text, openIndex) {
    let depth = 0;
    let quote = '';
    let escaped = false;

    for (let i = openIndex; i < text.length; i += 1) {
        const ch = text[i];

        if (quote) {
            if (escaped) {
                escaped = false;
                continue;
            }
            if (ch === '\\') {
                escaped = true;
                continue;
            }
            if (ch === quote) {
                quote = '';
            }
            continue;
        }

        if (ch === '"' || ch === "'" || ch === '`') {
            quote = ch;
            continue;
        }

        if (ch === '{') depth += 1;
        if (ch === '}') {
            depth -= 1;
            if (depth === 0) return i;
        }
    }

    return -1;
}

function extractFunctionByName(text, fnName) {
    const marker = `function ${fnName}(`;
    const start = text.indexOf(marker);
    if (start === -1) return '';

    const openBrace = text.indexOf('{', start);
    if (openBrace === -1) return '';

    const closeBrace = findMatchingBrace(text, openBrace);
    if (closeBrace === -1) return '';

    return text.slice(start, closeBrace + 1);
}

function hasFunctionDefinition(text, fnName) {
    return text.includes(`function ${fnName}(`);
}

function extractTopLevelExpressionAfterMarker(text, marker, endingChar) {
    const markerIndex = text.indexOf(marker);
    if (markerIndex === -1) return '';

    const start = markerIndex + marker.length;
    let quote = '';
    let escaped = false;
    let paren = 0;
    let brace = 0;
    let bracket = 0;

    for (let i = start; i < text.length; i += 1) {
        const ch = text[i];

        if (quote) {
            if (escaped) {
                escaped = false;
                continue;
            }
            if (ch === '\\') {
                escaped = true;
                continue;
            }
            if (ch === quote) {
                quote = '';
            }
            continue;
        }

        if (ch === '"' || ch === "'" || ch === '`') {
            quote = ch;
            continue;
        }

        if (ch === '(') paren += 1;
        if (ch === ')') paren -= 1;
        if (ch === '{') brace += 1;
        if (ch === '}') brace -= 1;
        if (ch === '[') bracket += 1;
        if (ch === ']') bracket -= 1;

        if (ch === endingChar && paren === 0 && brace === 0 && bracket === 0) {
            return text.slice(start, i).trim();
        }
    }

    return '';
}

function extractDocumentWriteExpressions(scriptContent) {
    const expressions = [];
    const marker = 'document.write(';
    let cursor = 0;

    while (cursor < scriptContent.length) {
        const start = scriptContent.indexOf(marker, cursor);
        if (start === -1) break;

        const from = start + marker.length;
        let quote = '';
        let escaped = false;
        let depth = 1;

        for (let i = from; i < scriptContent.length; i += 1) {
            const ch = scriptContent[i];

            if (quote) {
                if (escaped) {
                    escaped = false;
                    continue;
                }
                if (ch === '\\') {
                    escaped = true;
                    continue;
                }
                if (ch === quote) {
                    quote = '';
                }
                continue;
            }

            if (ch === '"' || ch === "'" || ch === '`') {
                quote = ch;
                continue;
            }

            if (ch === '(') {
                depth += 1;
                continue;
            }

            if (ch === ')') {
                depth -= 1;
                if (depth === 0) {
                    const expr = scriptContent.slice(from, i).trim();
                    if (expr) expressions.push(expr);
                    cursor = i + 1;
                    break;
                }
            }

            if (i === scriptContent.length - 1) {
                cursor = scriptContent.length;
            }
        }
    }

    return expressions;
}

function evaluateObfuscatedExpression(scriptContent, expression) {
    if (!expression) return '';

    const needed = new Set();
    const queue = [];
    const rootNames = expression.match(/_0x[0-9a-f]+/gi) || [];

    rootNames.forEach(name => {
        if (!needed.has(name)) {
            needed.add(name);
            queue.push(name);
        }
    });

    const functionBlocks = [];
    while (queue.length > 0) {
        const fnName = queue.shift();
        const block = extractFunctionByName(scriptContent, fnName);
        if (!block) continue;

        functionBlocks.push(block);

        const deps = block.match(/_0x[0-9a-f]+/gi) || [];
        deps.forEach(dep => {
            if (!needed.has(dep) && hasFunctionDefinition(scriptContent, dep)) {
                needed.add(dep);
                queue.push(dep);
            }
        });
    }

    if (functionBlocks.length === 0) {
        return '';
    }

    const initBlocks = [];
    for (const fnName of needed) {
        const callMarker = `}(${fnName},`;
        const callIdx = scriptContent.indexOf(callMarker);
        if (callIdx === -1) continue;

        let endIife = scriptContent.indexOf(');', callIdx);
        if (endIife < 0) continue;
        endIife += 2;

        let braceDepth = 1;
        let pos = callIdx - 1;
        while (pos >= 0 && braceDepth > 0) {
            const c = scriptContent[pos];
            if (c === '}') braceDepth += 1;
            if (c === '{') braceDepth -= 1;
            pos -= 1;
        }

        const funcIdx = scriptContent.lastIndexOf('(function(', pos + 2);
        if (funcIdx >= 0 && funcIdx > pos - 80) {
            initBlocks.push(scriptContent.slice(funcIdx, endIife));
        }
    }

    const evalBody = [
        ...functionBlocks,
        ...initBlocks,
        `var __VALUE=${expression};`,
        'return __VALUE;',
    ].join('\n');

    try {
        return String(Function(evalBody)() || '');
    } catch {
        return '';
    }
}

function extractExpressionFromIndex(text, startIndex) {
    let quote = '', escaped = false, paren = 0, brace = 0, bracket = 0;
    for (let i = startIndex; i < text.length; i += 1) {
        const ch = text[i];
        if (quote) {
            if (escaped) { escaped = false; continue; }
            if (ch === '\\') { escaped = true; continue; }
            if (ch === quote) { quote = ''; }
            continue;
        }
        if (ch === '"' || ch === "'" || ch === '`') { quote = ch; continue; }
        if (ch === '(') paren += 1;
        if (ch === ')') paren -= 1;
        if (ch === '{') brace += 1;
        if (ch === '}') brace -= 1;
        if (ch === '[') bracket += 1;
        if (ch === ']') bracket -= 1;
        if ((ch === ',' || ch === ';') && paren === 0 && brace === 0 && bracket === 0) {
            return text.slice(startIndex, i).trim();
        }
    }
    return '';
}

function decodeFromPlaylistStructure(scriptContent) {
    if (!scriptContent || !scriptContent.includes('hlsPlaylist')) return '';

    const hlsMatch = scriptContent.match(/\bhlsPlaylist\s*=\s*(_0x[0-9a-f]+)/i);
    if (!hlsMatch) return '';
    const playlistVar = hlsMatch[1];

    const objInit = playlistVar + '={}';
    const initIdx = scriptContent.indexOf(objInit);
    if (initIdx === -1) return '';

    const marker = playlistVar + '[';
    let cursor = initIdx + objInit.length;
    let sourcesVar = '';

    while (cursor < scriptContent.length) {
        const propIdx = scriptContent.indexOf(marker, cursor);
        if (propIdx === -1 || propIdx > initIdx + 5000) break;

        const bracketStart = propIdx + playlistVar.length;
        let bracketEnd = -1, depth = 0;
        for (let j = bracketStart; j < scriptContent.length; j += 1) {
            if (scriptContent[j] === '[') depth += 1;
            if (scriptContent[j] === ']') { depth -= 1; if (depth === 0) { bracketEnd = j; break; } }
        }
        if (bracketEnd === -1) break;
        if (scriptContent[bracketEnd + 1] !== '=') { cursor = bracketEnd + 1; continue; }

        const afterEq = bracketEnd + 2;
        const arrayMatch = scriptContent.slice(afterEq, afterEq + 50).match(/^\s*\[\s*(_0x[0-9a-f]+)\s*\]/);
        if (arrayMatch) { sourcesVar = arrayMatch[1]; break; }
        cursor = bracketEnd + 1;
    }

    if (!sourcesVar) return '';

    const srcInit = sourcesVar + '={}';
    const srcInitIdx = scriptContent.indexOf(srcInit);
    if (srcInitIdx === -1) return '';

    const srcSearchFrom = srcInitIdx + srcInit.length;
    const srcFirstProp = sourcesVar + '[';
    const srcPropIdx = scriptContent.indexOf(srcFirstProp, srcSearchFrom);
    if (srcPropIdx === -1) return '';

    const srcBracketStart = srcPropIdx + sourcesVar.length;
    let srcBracketEnd = -1, srcDepth = 0;
    for (let j = srcBracketStart; j < scriptContent.length; j += 1) {
        if (scriptContent[j] === '[') srcDepth += 1;
        if (scriptContent[j] === ']') { srcDepth -= 1; if (srcDepth === 0) { srcBracketEnd = j; break; } }
    }
    if (srcBracketEnd === -1 || scriptContent[srcBracketEnd + 1] !== '=') return '';

    const exprStart = srcBracketEnd + 2;
    const expression = extractExpressionFromIndex(scriptContent, exprStart);
    if (!expression) return '';

    return evaluateObfuscatedExpression(scriptContent, expression);
}

function decodeObfuscatedFileExpression(scriptContent) {
    if (!scriptContent || !scriptContent.includes("['file']=")) {
        return '';
    }

    const fileExpression = extractTopLevelExpressionAfterMarker(scriptContent, "['file']=", ',');
    return evaluateObfuscatedExpression(scriptContent, fileExpression);
}

function extractDirectMediaUrls(playerHtml) {
    const urls = [];
    const normalized = String(playerHtml || '').replace(/\\\//g, '/');

    const literalRegex = /https?:\/\/[^\s"'<>]+\.(?:m3u8|mp4)(?:\?[^\s"'<>]*)?/gi;
    let match;

    while ((match = literalRegex.exec(normalized)) !== null) {
        if (match[0]) urls.push(match[0]);
    }

    const scripts = extractInlineScripts(normalized);
    for (const script of scripts) {
        const decodedPlaylist = decodeFromPlaylistStructure(script);
        if (decodedPlaylist && /^https?:\/\//i.test(decodedPlaylist)) {
            urls.push(decodedPlaylist);
        }

        const decodedFile = decodeObfuscatedFileExpression(script);
        if (decodedFile && /^https?:\/\//i.test(decodedFile)) {
            urls.push(decodedFile);
        }

        const writeExpressions = extractDocumentWriteExpressions(script);
        for (const expr of writeExpressions) {
            const decodedWrite = evaluateObfuscatedExpression(script, expr);
            if (!decodedWrite) continue;

            let m;
            const writeUrlRegex = /https?:\/\/[^\s"'<>]+\.(?:m3u8|mp4)(?:\?[^\s"'<>]*)?/gi;
            while ((m = writeUrlRegex.exec(String(decodedWrite))) !== null) {
                if (m[0]) urls.push(m[0]);
            }
        }
    }

    return unique(urls);
}

async function resolveDirectFromPlayer(playerUrl, pageUrl) {
    try {
        const html = await fetchText(playerUrl, {
            headers: {
                ...HEADERS,
                Referer: pageUrl,
                Origin: BASE_URL,
            },
        });

        const directUrls = extractDirectMediaUrls(html);
        return directUrls.map(url => ({
            url,
            headers: {
                ...HEADERS,
                Referer: `${BASE_URL}/`,
                Origin: BASE_URL,
            },
        }));
    } catch {
        return [];
    }
}

function extractDownloadUrls($) {
    const urls = [];

    $('div.downloadLinks a[href]').each((_, a) => {
        const href = $(a).attr('href');
        if (!href) return;
        if (/^https?:\/\//i.test(href)) {
            urls.push(href);
        }
    });

    return unique(urls);
}

function buildStreams(pageUrl, directStreams, playerUrls, downloadUrls, quality) {
    const streams = [];

    directStreams.forEach((stream, index) => {
        streams.push({
            name: 'FaselHDX',
            title: `Direct Stream #${String(index + 1).padStart(2, '0')}`,
            url: stream.url,
            quality,
            headers: stream.headers,
        });
    });

    playerUrls.forEach((url, index) => {
        streams.push({
            name: 'FaselHDX',
            title: `Watch Server #${String(index + 1).padStart(2, '0')}`,
            url,
            quality,
            headers: {
                ...HEADERS,
                Referer: pageUrl,
            },
        });
    });

    downloadUrls.forEach((url, index) => {
        streams.push({
            name: 'FaselHDX',
            title: `Download Link #${String(index + 1).padStart(2, '0')}`,
            url,
            quality,
            headers: {
                ...HEADERS,
                Referer: pageUrl,
            },
        });
    });

    return streams;
}

export async function extractStreams(tmdbId, mediaType, season, episode) {
    console.log(`[FaselHDX] Resolving source for ${mediaType}:${tmdbId} s=${season || '-'} e=${episode || '-'}`);

    const pageUrl = await resolvePageUrl(tmdbId, mediaType, season, episode);
    if (!pageUrl) {
        console.log('[FaselHDX] No matching page found');
        return [];
    }

    console.log(`[FaselHDX] Selected page: ${pageUrl}`);

    const html = await fetchText(pageUrl, {
        headers: {
            ...HEADERS,
            Referer: `${BASE_URL}/main`,
        },
    });

    const $ = cheerio.load(html);
    const quality = resolveQualityFromPage($);

    const playerUrls = extractPlayerUrls($);
    const downloadUrls = extractDownloadUrls($);

    const directStreamsNested = await Promise.all(
        playerUrls.map(playerUrl => resolveDirectFromPlayer(playerUrl, pageUrl))
    );
    const directStreams = directStreamsNested.flat();

    const streams = buildStreams(pageUrl, directStreams, playerUrls, downloadUrls, quality);

    const deduped = [];
    const seen = new Set();

    for (const stream of streams) {
        if (!stream.url || seen.has(stream.url)) continue;
        seen.add(stream.url);
        deduped.push(stream);
    }

    console.log(`[FaselHDX] Found ${deduped.length} stream candidates`);
    return deduped;
}
